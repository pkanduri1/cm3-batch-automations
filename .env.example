# Oracle Database Configuration
# DSN format: hostname:port/service_name  (e.g. localhost:1521/FREEPDB1)
# NOTE: Oracle Instant Client is NOT required — uses oracledb thin mode.
ORACLE_USER=CM3INT
ORACLE_PASSWORD=your_password_here
ORACLE_DSN=localhost:1521/FREEPDB1
# Schema prefix for SQL table references (defaults to ORACLE_USER if unset)
ORACLE_SCHEMA=CM3INT

# Application Configuration
ENVIRONMENT=dev
LOG_LEVEL=INFO

# API Security
# API_KEYS supports comma-separated values; optional role suffix (`key:role`) is
# accepted for future RBAC support.
API_KEYS=key-dev-abc123
ALLOWED_ORIGINS=http://localhost,http://127.0.0.1

# File Retention (hours) — uploaded/temp files older than this are deleted on startup
FILE_RETENTION_HOURS=24
